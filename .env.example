# Google Gemini API Configuration
GEMINI_API_KEY=your-api-key-here

# Model Selection (optional)
# Set to 'true' to allow experimental/preview models as defaults
# If not set or 'false', only stable production models will be used
# GEMINI_ALLOW_EXPERIMENTAL=false

# Deep Research (real Google Deep Research via the Interactions API)
# GEMINI_DEEP_RESEARCH_AGENT=deep-research-pro-preview-12-2025
#   options: deep-research-pro-preview-12-2025 (default),
#            deep-research-preview-04-2026, deep-research-max-preview-04-2026

# Gemini Agents via the `agy` CLI (optional)
# The agent tools (gemini_agent / gemini_agent_models) shell out to `agy`,
# which uses its own login (Antigravity / Cloud Code) — no GEMINI_API_KEY needed.
# GEMINI_AGY_BIN=agy                  # path/name of the agy executable
# GEMINI_AGY_MODEL=                   # default model label, e.g. "Gemini 3.1 Pro (High)"
# GEMINI_AGY_TIMEOUT_SECONDS=600      # default hard timeout per agent run
# GEMINI_AGY_AUTO_APPROVE=true        # auto-approve tool calls (false = require prompts)

# Multi-provider agents via the `opencode` harness (optional)
# The agent_* tools (agent_spawn / agent_send / agent_status / agent_thoughts /
# agent_cost / agent_models / agent_stop) drive opencode, which handles provider
# auth itself (configure via `opencode auth login`, e.g. OpenRouter for GLM).
# Execution runs as a detached `opencode run`; introspection uses a headless
# `opencode serve` started on demand. No model API key is needed in this MCP.
# OPENCODE_BIN=opencode                            # path/name of the opencode executable
# OPENCODE_DEFAULT_MODEL=openrouter/z-ai/glm-5.2   # provider/model for spawned agents
# OPENCODE_DEFAULT_VARIANT=high                    # reasoning effort: minimal|low|high|max
# OPENCODE_DEFAULT_DIR=                            # default working directory for agents
# OPENCODE_HANDSHAKE_SECONDS=30                    # wait for server ready / session id
# NOTE: GLM-5.2 with high thinking is powerful but pricey — the first message in a
# session is never cached (full price); follow-ups reuse the cached prefix (cheap).

# Logging Configuration
LOG_LEVEL=info

# Server Configuration (optional)
# These are set in code but can be overridden
# SERVER_NAME=gemini-mcp
# SERVER_VERSION=1.0.0
